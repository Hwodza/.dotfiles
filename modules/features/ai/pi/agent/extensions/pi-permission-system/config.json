{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",

  "debugLog": true,
  "permissionReviewLog": true,
  "yoloMode": false,

  "permission": {
    "*": "allow",

    "ls": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "tree": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "read": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "write": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "edit": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "find": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "grep": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "rg": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },
    "cat": {
      "/*": "ask",
      "~/**": "ask",
      "*..*": "ask"
    },

    "external_directory": {
      "*": "ask",
      "/nix/store/*": "allow"
    },

    "mcp": {
      "*": "ask",
      "mcp_status": "allow",
      "mcp_list": "allow",
      "mcp_search": "allow",
      "mcp_describe": "allow",
      "mcp_connect": "allow",
      "searxng-research": "allow",
      "searxng-research:*": "allow"
    },

    "bash": {
      "*": "ask",

      "* /*": "ask",
      "* ~*": "ask",
      "* ..*": "ask",

      "ls /nix/store/*": "allow",
      "tree /nix/store/*": "allow",
      "cat /nix/store/*": "allow",
      "rg */nix/store/*": "allow",
      "grep */nix/store/*": "allow",
      "find /nix/store/*": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "git check-ignore*": "allow",

      "nix eval *": "allow",
      "nix build *": "allow",
      "nix flake show *": "allow",
      "nix flake metadata *": "allow",
      "nix search *": "allow",
      "nix-instantiate *": "allow",
      "statix check *": "allow",
      "deadnix *": "allow",
      "alejandra --check *": "allow",
      "nixfmt --check *": "allow",

      "mypy *": "allow",
      "flake8 *": "allow",
      "pylint *": "allow",
      "black --check *": "allow",
      "ruff check *": "allow",
      "ruff check *--fix*": "ask",

      "cargo check*": "allow",
      "cargo fmt --check*": "allow",
      "cargo clippy*": "allow",
      "cargo clippy *--fix*": "ask",

      "luacheck *": "allow",
      "stylua --check *": "allow"
    }
  }
}
